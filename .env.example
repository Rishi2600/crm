# Database (PostgreSQL)
# Local:   postgresql://USER:PASSWORD@localhost:5432/crm_dashboard
# Neon:    postgresql://USER:PASSWORD@ep-xxx.neon.tech/crm_dashboard?sslmode=require
# Supabase: postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_dashboard"

# JWT Secret — use a long random string in production
# Generate: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# JWT expiry
JWT_EXPIRES_IN="7d"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
