// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 1. USERS ────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(SALES_REP)
  status    Status   @default(ACTIVE)
  managerId String?  @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Reporting hierarchy — self-relation. A user has at most one manager,
  // and can have many direct reports. Depth is intentionally ONE LEVEL only
  // (direct reports, not the full recursive subtree) — see Tasks module's
  // /api/users/assignable route for where this gets enforced.
  manager       User?  @relation("ManagerHierarchy", fields: [managerId], references: [id])
  directReports User[] @relation("ManagerHierarchy")

  // Relations
  contacts       Contact[]
  deals          Deal[]
  activities     Activity[]
  assignedTasks  Task[]         @relation("TaskAssignee")
  createdTasks   Task[]         @relation("TaskCreator")
  taskActivities TaskActivity[]

  @@map("users")
}

// ─── 2. COMPANIES ────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  companyName String   @map("company_name")
  industry    String?
  website     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  contacts Contact[]

  @@map("companies")
}

// ─── 3. CONTACTS ─────────────────────────────────────────────────────────────

model Contact {
  id          String        @id @default(cuid())
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String        @unique
  phone       String?
  companyId   String?       @map("company_id")
  location    String?
  leadStatus  LeadStatus    @default(WARM) @map("lead_status")
  isFavourite Boolean       @default(false) @map("is_favourite")
  ownerId     String        @map("owner_id")
  status      ContactStatus @default(ACTIVE)   // lifecycle: kept alongside leadStatus
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  owner         User           @relation(fields: [ownerId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id])
  deals         Deal[]
  taskAttendees TaskAttendee[] // meeting attendance, via Tasks module

  // Indexes — per story's performance section
  @@index([email])
  @@index([companyId])
  @@index([ownerId])
  @@index([createdAt])
  @@index([firstName])
  @@index([lastName])
  @@map("contacts")
}

// ─── 4. DEALS ────────────────────────────────────────────────────────────────

model Deal {
  id                String      @id @default(cuid())
  title             String
  contactId         String      @map("contact_id")
  ownerId           String      @map("owner_id")
  amount            Decimal     @db.Decimal(12, 2)
  stage             DealStage   @default(QUALIFICATION)
  status            DealStatus  @default(OPEN)
  probability       Int         @default(0)   // 0–100, validated at the API layer (see deals/pipeline route)
  expectedCloseDate DateTime?   @map("expected_close_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  contact Contact @relation(fields: [contactId], references: [id])
  owner   User    @relation(fields: [ownerId], references: [id])
  tasks   Task[]  // tasks optionally linked via Task.relatedDealId

  // Indexes — per Deals Pipeline story's performance section
  @@index([ownerId])
  @@index([contactId])
  @@index([stage])
  @@index([status])
  @@index([expectedCloseDate])
  @@index([createdAt])
  @@map("deals")
}

// ─── 5. ACTIVITIES ───────────────────────────────────────────────────────────
// entityId is polymorphic — it can reference a Deal, Contact, Task, or User.
// Because it points to multiple tables, we intentionally do NOT add a Prisma
// relation or a database FK here. Lookups are done in application code.

model Activity {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  activityType ActivityType @map("activity_type")
  entityType   EntityType   @map("entity_type")
  entityId     String       @map("entity_id")  // no FK — polymorphic reference
  message      String
  createdAt    DateTime     @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("activities")
}

// ─── 6. TASKS ────────────────────────────────────────────────────────────────

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  // "type" distinguishes a plain task from one that carries meeting details
  // (TaskActivity rows + TaskAttendee rows). Not in the story's column list
  // explicitly — added so the frontend can filter "show me my meetings"
  // without inferring it from whether related rows happen to exist.
  type          TaskType     @default(STANDARD)
  dueDate       DateTime?    @map("due_date")
  relatedDealId String?      @map("related_deal_id")
  assignedTo    String       @map("assigned_to")
  createdBy     String       @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations — two separate User relations (who it's assigned to vs. who
  // created it) require explicit relation names since Prisma can't infer
  // which foreign key maps to which relation when there's more than one
  // path between the same two models.
  assignee    User           @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator     User           @relation("TaskCreator", fields: [createdBy], references: [id])
  relatedDeal Deal?          @relation(fields: [relatedDealId], references: [id])
  activities  TaskActivity[]
  attendees   TaskAttendee[]

  // Indexes — per story's performance section
  @@index([assignedTo])
  @@index([createdBy])
  @@index([status])
  @@index([dueDate])
  @@index([relatedDealId])
  @@map("tasks")
}

// ─── 7. TASK ACTIVITIES ──────────────────────────────────────────────────────
// Renamed from the story's "Activities" table to avoid colliding with the
// PRE-EXISTING `Activity` model (dashboard's audit-log / Recent Activity
// feed — a completely different concept that happens to share a name in
// the story documents). This table holds meeting/call/follow-up DETAILS
// attached to a specific task; the original `Activity` model is untouched.

model TaskActivity {
  id           String           @id @default(cuid())
  taskId       String           @map("task_id")
  activityType TaskActivityType @map("activity_type")
  meetingDate  DateTime?        @map("meeting_date")
  meetingTime  String?          @map("meeting_time") // stored as "HH:mm" — kept as a simple string since the story treats date/time as separate fields
  location     String?
  notes        String?
  createdBy    String           @map("created_by")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Relations
  task    Task @relation(fields: [taskId], references: [id])
  creator User @relation(fields: [createdBy], references: [id])

  @@index([taskId])
  @@map("task_activities")
}

// ─── 8. TASK ATTENDEES ────────────────────────────────────────────────────────
// Join table — a task (if it's a meeting) can have many attendees, and a
// contact can be an attendee on many different tasks/meetings over time.

model TaskAttendee {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  contactId String   @map("contact_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  task    Task    @relation(fields: [taskId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  // Prevents adding the same contact as an attendee on the same task twice
  @@unique([taskId, contactId])
  @@index([taskId])
  @@index([contactId])
  @@map("task_attendees")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  SALES_REP
}

enum Status {
  ACTIVE
  INACTIVE
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  LEAD
}

// Sales temperature — separate axis from ContactStatus (lifecycle).
// Story's "Lead Status" section: Hot / Warm / Cold, enforced at DB level.
enum LeadStatus {
  HOT
  WARM
  COLD
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealStage {
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
}

enum ActivityType {
  DEAL_CREATED
  DEAL_UPDATED
  MEETING_SCHEDULED
  CONTACT_UPDATED
  EMAIL_SENT
  TASK_COMPLETED
  NOTE_ADDED
}

enum EntityType {
  DEAL
  CONTACT
  TASK
  USER
}

// TaskStatus renamed from the original PENDING/IN_PROGRESS/COMPLETED/CANCELLED
// to match this story's exact spec (TODO/IN_PROGRESS/COMPLETED). CANCELLED
// was intentionally dropped rather than assumed — flagged as reversible if
// a "cancelled" state turns out to be needed later.
enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

// Distinguishes a plain task from a meeting-carrying one — see the note on
// Task.type above for why this is explicit rather than inferred.
enum TaskType {
  STANDARD
  MEETING
}

enum TaskActivityType {
  MEETING
  CALL
  FOLLOW_UP
}
